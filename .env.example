# Variabili d'ambiente — TiSposi
# Copia questo file in .env.local per sviluppo locale
# Su Vercel, aggiungile nelle impostazioni "Environment Variables"

# ─────────────────────────────────────────────
# SERVER-SIDE (Vercel Functions) — NON esporre al client
# ─────────────────────────────────────────────

# JSON del Service Account Google (stringificato su una riga)
# Ottienilo da: GCP Console → IAM → Service Accounts → Crea chiave → JSON
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID della cartella Google Drive dove salvare le foto
# Ottienilo dall'URL della cartella: drive.google.com/drive/folders/QUESTO_ID
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ─────────────────────────────────────────────
# CLIENT-SIDE (visibili nel bundle JS — solo dati non sensibili)
# ─────────────────────────────────────────────

VITE_WEDDING_COUPLE=Martina & Natan
VITE_WEDDING_DATE=10 Ottobre 2026
