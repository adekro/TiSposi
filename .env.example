# Variabili d'ambiente — TiSposi
# Copia questo file in .env.local per sviluppo locale
# Su Vercel, aggiungile nelle impostazioni "Environment Variables"

# ─────────────────────────────────────────────
# SERVER-SIDE (Vercel Functions) — NON esporre al client
# ─────────────────────────────────────────────

# Supabase server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Drive opzionale: usato solo per gli eventi configurati con provider google_drive
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# ─────────────────────────────────────────────
# CLIENT-SIDE (visibili nel bundle JS — solo dati non sensibili)
# ─────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_WEDDING_COUPLE=Ti Sposi
VITE_WEDDING_DATE=Crea il tuo evento

# Setup DB richiesto: esegui lo schema in supabase/schema.sql
